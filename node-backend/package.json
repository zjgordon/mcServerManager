{
  "name": "minecraft-server-manager-backend",
  "version": "2.0.0",
  "description": "Node.js/Express backend for Minecraft Server Manager",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --config nodemon.dev.json",
    "dev:debug": "nodemon --config nodemon.dev.json --inspect",
    "dev:server": "ts-node scripts/dev-server.ts",
    "build": "npm run openapi:gen && tsc",
    "build:watch": "tsc --watch",
    "build:prod": "ts-node scripts/build-production.ts",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --config vitest.config.coverage.ts --coverage",
    "test:ui": "vitest --ui",
    "test:contract": "vitest --config vitest.contract.config.ts",
    "test:contract:watch": "vitest --config vitest.contract.config.ts --watch",
    "test:all": "npm run test && npm run test:contract",
    "test:runner": "ts-node scripts/test-runner.ts",
    "openapi:gen": "ts-node scripts/generate-openapi.ts",
    "openapi:check": "npm run openapi:gen && git diff --exit-code docs/openapi.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts --max-warnings 0",
    "lint:prod": "eslint src/**/*.ts --config .eslintrc.prod.js",
    "lint:scripts": "eslint scripts/**/*.ts",
    "lint:scripts:fix": "eslint scripts/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"scripts/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"scripts/**/*.{ts,js}\"",
    "type-check": "tsc --noEmit",
    "type-check:prod": "tsc --project tsconfig.prod.json --noEmit",
    "quality": "ts-node scripts/code-quality.ts",
    "quality:fix": "ts-node scripts/code-quality.ts --fix",
    "quality:check": "ts-node scripts/code-quality.ts --check",
    "quality:strict": "ts-node scripts/code-quality.ts --strict",
    "clean": "rm -rf dist coverage test-results.* contract-test-results.* eslint-results.json code-quality-report.json monitoring-report.json deploy-report.json",
    "prebuild": "npm run clean && npm run type-check && npm run lint:check",
    "precommit": "npm run format && npm run lint:fix && npm run type-check",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:deploy": "prisma migrate deploy",
    "db:backup": "ts-node scripts/backup-database.ts",
    "db:restore": "ts-node scripts/restore-database.ts",
    "setup:db": "ts-node scripts/setup-database.ts",
    "migrate:flask": "ts-node scripts/migrate-from-flask.ts",
    "test:db": "ts-node scripts/test-database.ts",
    "test:middleware": "ts-node scripts/test-middleware.ts",
    "validate:db": "npm run test:db && npm run db:seed",
    "validate:middleware": "npm run test:middleware",
    "redis:setup": "ts-node scripts/setup-redis.ts",
    "redis:test": "ts-node scripts/test-redis.ts",
    "redis:services:test": "ts-node scripts/test-redis-services.ts",
    "test:auth": "ts-node scripts/test-auth.ts",
    "test:validation": "ts-node scripts/test-validation-simple.ts",
    "test:auth:contract": "ts-node scripts/test-auth-contract.ts",
    "test:auth:simple": "ts-node scripts/test-auth-simple.ts",
    "test:server:contract": "ts-node scripts/test-server-contract.ts",
    "test:server:simple": "ts-node scripts/test-server-simple.ts",
    "test:admin:contract": "ts-node scripts/test-admin-contract.ts",
    "test:admin:simple": "ts-node scripts/test-admin-simple.ts",
    "test:zod:validation": "ts-node scripts/test-zod-validation.ts",
    "test:rate:limiting": "ts-node scripts/test-rate-limiting-security.ts",
    "test:error:handling": "ts-node scripts/test-error-handling.ts",
    "test:contract:parity": "ts-node scripts/test-contract-parity.ts",
    "test:contract:compliance": "ts-node scripts/validate-contract-compliance.ts",
    "express:setup": "ts-node scripts/setup-express-service.ts",
    "express:service": "ts-node scripts/express-service-manager.ts",
    "express:test": "ts-node scripts/test-express-service.ts",
    "redis:start": "docker-compose -f docker-compose.redis.yml up -d",
    "redis:stop": "docker-compose -f docker-compose.redis.yml down",
    "redis:logs": "docker-compose -f docker-compose.redis.yml logs -f",
    "docker:build": "docker build -t mcserver-backend .",
    "docker:build:prod": "docker build -f Dockerfile.prod -t mcserver-backend:prod .",
    "docker:run": "docker run -p 5001:5001 --env-file .env mcserver-backend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "deploy": "ts-node scripts/deploy.ts",
    "deploy:no-test": "ts-node scripts/deploy.ts --no-test",
    "deploy:push": "ts-node scripts/deploy.ts --push",
    "monitoring": "ts-node scripts/monitoring.ts",
    "monitoring:alerts": "ts-node scripts/monitoring.ts --alerts",
    "monitoring:dashboard": "ts-node scripts/monitoring.ts --dashboard",
    "smoke": "ts-node scripts/dev-smoke.ts",
    "validate": "npm run type-check && npm run lint:check && npm run format:check",
    "validate:prod": "npm run type-check:prod && npm run lint:prod && npm run format:check",
    "ci": "npm run validate && npm run test:all",
    "ci:prod": "npm run validate:prod && npm run test:all"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@socket.io/redis-adapter": "^8.2.1",
    "@types/sqlite3": "^3.1.11",
    "@types/swagger-ui-express": "^4.1.8",
    "archiver": "^6.0.1",
    "async-mutex": "^0.4.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.18.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.7.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "prisma": "^5.7.1",
    "prom-client": "^15.1.0",
    "redis": "^4.6.10",
    "redlock": "^5.0.0-beta.2",
    "socket.io": "^4.8.1",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "systeminformation": "^5.21.19",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.5.1",
    "zod-to-openapi": "^0.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/fs-extra": "^11.0.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "socket.io-client": "^4.7.4",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
